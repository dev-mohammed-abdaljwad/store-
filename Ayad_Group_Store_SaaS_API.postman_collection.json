              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/cash/daily-report?date=2024-01-01", "host": ["{{base_url}}"], "path": ["store", "cash", "daily-report"], "query": [{ "key": "date", "value": "2024-01-01" }] }
