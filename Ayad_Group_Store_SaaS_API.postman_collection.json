                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"supplier_id\": 1,\n  \"paid_amount\": 0,\n  \"notes\": \"استلام شحنة\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"ordered_quantity\": 100,\n      \"received_quantity\": 100,\n      \"unit_price\": 100\n    }\n  ]\n}"
                },
                "url": { "raw": "{{base_url}}/store/purchase-invoices", "host": ["{{base_url}}"], "path": ["store", "purchase-invoices"] }
              }
            },
            {
              "name": "Cancel Purchase Invoice",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"reason\": \"رد الشحنة لوجود عيوب\"\n}" },
                "url": { "raw": "{{base_url}}/store/purchase-invoices/1/cancel", "host": ["{{base_url}}"], "path": ["store", "purchase-invoices", "1", "cancel"] }
              }
            }
          ]
        },
        {
          "name": "Payments",
          "item": [
            {
              "name": "Collect From Customer (سند قبض)",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"party_id\": 1,\n  \"amount\": 500,\n  \"notes\": \"دفعة من حساب\"\n}" },
                "url": { "raw": "{{base_url}}/store/payments/customer", "host": ["{{base_url}}"], "path": ["store", "payments", "customer"] }
              }
            },
            {
              "name": "Pay To Supplier (سند صرف)",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
