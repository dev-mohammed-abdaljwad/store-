                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"amount\": 50000\n}" },
                "url": { "raw": "{{base_url}}/store/cash/opening-balance", "host": ["{{base_url}}"], "path": ["store", "cash", "opening-balance"] }
              }
            },
            {
              "name": "Current Balance",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/cash/balance", "host": ["{{base_url}}"], "path": ["store", "cash", "balance"] }
              }
