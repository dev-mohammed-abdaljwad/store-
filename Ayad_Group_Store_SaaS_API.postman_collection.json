            {
              "name": "Create Product",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"category_id\": 1,\n  \"name\": \"سماد مخصص\",\n  \"sku\": \"PROD-001\",\n  \"unit\": \"كيس\",\n  \"purchase_price\": 100,\n  \"sale_price\": 150,\n  \"low_stock_threshold\": 10\n}" },
                "url": { "raw": "{{base_url}}/store/products", "host": ["{{base_url}}"], "path": ["store", "products"] }
              }
            }
          ]
        },
        {
          "name": "Customers",
          "item": [
            {
              "name": "List Customers",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/customers", "host": ["{{base_url}}"], "path": ["store", "customers"] }
              }
            },
            {
              "name": "Create Customer",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"عميل جديد\",\n  \"phone\": \"0555555555\",\n  \"address\": \"الرياض\"\n}" },
                "url": { "raw": "{{base_url}}/store/customers", "host": ["{{base_url}}"], "path": ["store", "customers"] }
              }
            },
            {
              "name": "Customer Statement",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/customers/1/statement", "host": ["{{base_url}}"], "path": ["store", "customers", "1", "statement"] }
              }
            }
          ]
        },
        {
          "name": "Suppliers",
          "item": [
            {
              "name": "List Suppliers",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
