              "name": "Create Supplier",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"name\": \"مورد جديد\",\n  \"phone\": \"0555555555\",\n  \"address\": \"الدمام\"\n}" },
                "url": { "raw": "{{base_url}}/store/suppliers", "host": ["{{base_url}}"], "path": ["store", "suppliers"] }
              }
            },
            {
              "name": "Supplier Statement",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/suppliers/1/statement", "host": ["{{base_url}}"], "path": ["store", "suppliers", "1", "statement"] }
              }
            }
          ]
        },
        {
          "name": "Sales Invoices",
          "item": [
            {
              "name": "List Sales Invoices",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
                "url": { "raw": "{{base_url}}/store/sales-invoices", "host": ["{{base_url}}"], "path": ["store", "sales-invoices"] }
              }
            },
            {
              "name": "Create Sales Invoice",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"customer_id\": 1,\n  \"paid_amount\": 100,\n  \"notes\": \"بيان بيع\",\n  \"items\": [\n    {\n      \"product_id\": 1,\n      \"quantity\": 2,\n      \"unit_price\": 150\n    }\n  ]\n}"
                },
                "url": { "raw": "{{base_url}}/store/sales-invoices", "host": ["{{base_url}}"], "path": ["store", "sales-invoices"] }
              }
            },
            {
              "name": "Cancel Sales Invoice",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "POST",
                "header": [{ "key": "Accept", "value": "application/json" }, { "key": "Content-Type", "value": "application/json" }],
                "body": { "mode": "raw", "raw": "{\n  \"reason\": \"إرجاع العميل للطلب بالكامل\"\n}" },
                "url": { "raw": "{{base_url}}/store/sales-invoices/1/cancel", "host": ["{{base_url}}"], "path": ["store", "sales-invoices", "1", "cancel"] }
              }
            }
          ]
        },
        {
          "name": "Purchase Invoices",
          "item": [
            {
              "name": "List Purchase Invoices",
              "request": {
                "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
                "method": "GET",
                "header": [{ "key": "Accept", "value": "application/json" }],
