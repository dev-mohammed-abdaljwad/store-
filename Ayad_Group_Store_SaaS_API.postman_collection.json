                "body": { "mode": "raw", "raw": "{\n  \"party_id\": 1,\n  \"amount\": 1000,\n  \"notes\": \"سداد دفعة للمورد\"\n}" },
                "url": { "raw": "{{base_url}}/store/payments/supplier", "host": ["{{base_url}}"], "path": ["store", "payments", "supplier"] }
              }
            }
          ]
